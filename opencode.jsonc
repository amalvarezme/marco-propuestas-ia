{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orquestador",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "openalex": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/openalex-mcp-server"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "OPENALEX_API_KEY": "{env:CONTACT_EMAIL}"
      }
    },
    "crossref": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/crossref-mcp-server@latest"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "CROSSREF_MAILTO": "{env:CONTACT_EMAIL}"
      }
    },
    "pubmed": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/pubmed-mcp-server@latest"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "NCBI_ADMIN_EMAIL": "{env:CONTACT_EMAIL}"
      }
    },
    "arxiv": {
      "type": "local",
      "command": ["npx", "-y", "@cyanheads/arxiv-mcp-server@latest"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    },
    "semanticscholar": {
      "type": "local",
      "command": ["npx", "-y", "@xbghc/semanticscholar-mcp"],
      "enabled": true,
      "timeout": 60000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
