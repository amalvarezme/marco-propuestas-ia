# macOS
.DS_Store

# Local agent indexes / caches
.atl/
.codegraph/

# Obsidian local app state (workspace, plugin config)
.obsidian/

# Knowledge-graph scratch (from /graphify runs)
graphify-out/

# Python bytecode cache
__pycache__/
*.pyc

# LaTeX build artifacts
**/*.aux
**/*.bbl
**/*.bcf
**/*.blg
**/*.fdb_latexmk
**/*.fls
**/*.log
**/*.out
**/*.run.xml
**/*.synctex.gz
**/*.toc
**/*.lof
**/*.lot
proposal/*.pdf

# --- Contenido generado por corridas de /propuesta -----------------------
# El repo solo versiona el esqueleto del framework (build.sh, scripts/,
# logos/, templates/); todo lo que /propuesta produce por corrida se
# descarta aquí para que un `git add -A` después de una corrida real nunca
# vuelva a subir contenido de una propuesta específica.
proposal/main.tex
proposal/main.docx
proposal/refs.bib
proposal/insumos.md
proposal/estado_propuesta.md
proposal/guia_ajustada_TDR.md
proposal/sections/
proposal/pipeline/
proposal/scoping/
proposal/pixelshot-out/

# Insumos y notas de vault por corrida (se conserva el placeholder de carpeta)
vault/insumos/*
!vault/insumos/.gitkeep
vault/secciones/*
!vault/secciones/.gitkeep

# Insumos de usuario (PDFs/DOCX de la convocatoria) — específicos de cada
# corrida, no del framework base
info_data/*
!info_data/.gitkeep

# --- Corridas archivadas de /propuesta ------------------------------------
# proposals/<run-id>/ contiene el volcado completo (proposal/ + vault/) de
# una corrida ya cerrada. Es contenido de propuesta, igual que lo de arriba:
# nunca se sincroniza con GitHub, solo vive en el disco local de quien corrió
# el pipeline. Se conserva `proposals/registry.md` (índice de metadatos:
# run-id, fechas, idea breve, ruta local — sin contenido de la propuesta en
# sí), que sí se versiona.
proposals/*/
